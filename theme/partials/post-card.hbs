{{!-- Standard Post Card --}}
<article class="post-card {{post_class}}">

    {{!-- Featured image --}}
    {{#if feature_image}}
    <a href="{{url}}" class="post-card-image-link" aria-hidden="true" tabindex="-1">
        <img
            class="post-card-image"
            src="{{img_url feature_image size="m"}}"
            srcset="{{img_url feature_image size="s"}} 300w,
                    {{img_url feature_image size="m"}} 600w,
                    {{img_url feature_image size="l"}} 1000w"
            sizes="(max-width: 600px) 100vw, (max-width: 1200px) 50vw, 400px"
            alt="{{title}}"
            loading="lazy"
        >
    </a>
    {{/if}}

    <div class="post-card-body">

        {{!-- Primary tag label --}}
        {{#if primary_tag}}
        <div class="post-card-tags">
            <a href="{{primary_tag.url}}" class="post-card-tag">{{primary_tag.name}}</a>
        </div>
        {{/if}}

        {{!-- Title --}}
        <h2 class="post-card-title">
            <a href="{{url}}">{{title}}</a>
        </h2>

        {{!-- Excerpt --}}
        {{#if excerpt}}
        <p class="post-card-excerpt">{{excerpt words="30"}}</p>
        {{/if}}

        {{!-- Footer meta --}}
        <footer class="post-card-footer">
            <time class="post-card-date" datetime="{{date format="YYYY-MM-DD"}}">
                {{date format="MMM D, YYYY"}}
            </time>
            <span class="post-card-sep" aria-hidden="true">&middot;</span>
            <span class="post-card-reading-time">{{reading_time}}</span>
        </footer>

    </div>
</article>
