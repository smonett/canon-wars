{{!< default}}

{{#author}}
<div class="author-archive">

    {{!-- Author header --}}
    <header class="author-header">
        <div class="container">
            <div class="author-header-content">
                {{#if profile_image}}
                <img
                    src="{{img_url profile_image size="s"}}"
                    alt="{{name}}"
                    class="author-profile-image"
                >
                {{/if}}

                <h1 class="author-header-name">{{name}}</h1>

                {{#if bio}}
                <p class="author-header-bio">{{bio}}</p>
                {{/if}}

                <div class="author-header-links">
                    {{#if location}}
                    <span class="author-header-location">📍 {{location}}</span>
                    {{/if}}
                    {{#if website}}
                    <a href="{{website}}" class="author-website" rel="noopener" target="_blank">Website ↗</a>
                    {{/if}}
                    {{#if twitter}}
                    <a href="https://twitter.com/{{twitter}}" class="author-social" rel="noopener" target="_blank">@{{twitter}}</a>
                    {{/if}}
                </div>
            </div>
        </div>
    </header>

    {{!-- Post grid --}}
    <section class="post-grid-section" aria-label="Posts by {{name}}">
        <div class="container">
            <div class="post-grid">
                {{#foreach posts}}
                    {{#has tag="cogs-log"}}
                        {{> cogs-log-card}}
                    {{else}}
                        {{> post-card}}
                    {{/has}}
                {{/foreach}}
            </div>

            {{pagination}}
        </div>
    </section>

</div>
{{/author}}
