{{!< default}}

{{#post}}
<div class="page-content">
    <div class="container">

        {{#match @page.show_title_and_feature_image}}
        <header class="page-header">
            {{#if primary_tag}}
            <div class="page-tag-label">
                <a href="{{primary_tag.url}}" class="post-tag">{{primary_tag.name}}</a>
            </div>
            {{/if}}
            <h1 class="page-title">{{title}}</h1>
            {{#if custom_excerpt}}
            <p class="page-excerpt">{{custom_excerpt}}</p>
            {{/if}}
        </header>

        {{#if feature_image}}
        <figure class="page-feature-image">
            <img
                src="{{img_url feature_image size="l"}}"
                srcset="{{img_url feature_image size="m"}} 600w,
                        {{img_url feature_image size="l"}} 1000w"
                sizes="(max-width: 720px) 100vw, 720px"
                alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
            >
            {{#if feature_image_caption}}
            <figcaption>{{feature_image_caption}}</figcaption>
            {{/if}}
        </figure>
        {{/if}}
        {{/match}}

        <div class="page-body gh-content">
            {{content}}
        </div>

    </div>
</div>
{{/post}}
